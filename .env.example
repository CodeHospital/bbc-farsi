TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL=@YourChannelName

# Only used for the admin "debug curl" panels now — the Rails app no longer
# calls Ollama. The worker client (worker/worker.rb) does the LLM calls.
OLLAMA_URL=http://localhost:11434

# Shared bearer token the worker client uses to authenticate to /api/tasks.
# Set the SAME value here and in the worker's environment.
WORKER_API_TOKEN=generate_a_long_random_secret

# ── llmarkt (vibeearning) LLM Grid — PRIMARY LLM backend ─────────────────────
# When configured, enqueued tasks are submitted to the llmarkt grid and results
# arrive via webhook (the Ollama worker above becomes a fallback). These can be
# set either here OR (preferred) in Rails credentials as llmarkt_api_url /
# llmarkt_api_key / app_base_url. Credentials take precedence over ENV.
#
# LLMARKT_API_URL=https://llmarkt.codehospital.com/api/v1
# LLMARKT_API_KEY=your_llmarkt_bearer_token
# LLMARKT_MODEL_MATCH=family            # "family" (default) or "exact"
# Public URL of THIS app, used to build webhook callback URLs llmarkt can reach:
# APP_BASE_URL=https://news.example.com

# Required — app refuses to start without these (no default fallback), set
# either here OR (preferred) in Rails credentials as admin_username /
# admin_password / admin_email (see AdminBootstrap). Credentials take
# precedence over ENV. Only used once, by `bin/rails db:seed`, to bootstrap
# the first admin `User` row (skipped if the users table already has anyone
# in it). After that, manage accounts at /admin/users — neither source is
# read at login time.
ADMIN_USERNAME=choose_a_username
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_EMAIL=admin@example.com

# ── Outgoing mail (Resend) — password reset emails ───────────────────────────
# Sent via Resend's SMTP relay (smtp.resend.com), no extra gem required. These
# can be set either here OR (preferred) in Rails credentials as
# resend_api_key / sender_email. Credentials take precedence over ENV.
# Without these, mail sending is a no-op (perform_deliveries is off) rather
# than raising — the "forgot password" flow still runs, it just won't
# actually send anything until Resend is configured.
#
# RESEND_API_KEY=re_your_resend_api_key
# SENDER_EMAIL=BBC Farsi <noreply@yourdomain.com>

# Production only — PostgreSQL connection string. Development/test use SQLite and
# ignore this. Example: postgres://user:password@host:5432/bbcfarsi_production
# DATABASE_URL=

# ── Telegram admin notification bot ──────────────────────────────────────────
# A separate bot (not a TelegramChannel row) that DMs an admin/editor chat
# whenever a translation is ready for review, with inline buttons: request
# rewrite / retranslation / refine, publish to a channel, publish/unpublish on
# the portal, or flag for manual editor edit. Prefer Rails credentials
# (telegram_admin_bot_token / telegram_admin_chat_id / telegram_admin_webhook_secret)
# over these. Register the webhook once via `bin/rails telegram_admin:set_webhook`
# (needs Llmarkt.app_base_url / APP_BASE_URL set too, so Telegram can reach it).
#
# TELEGRAM_ADMIN_BOT_TOKEN=your_admin_bot_token_here
# TELEGRAM_ADMIN_CHAT_ID=your_telegram_user_or_group_chat_id
# TELEGRAM_ADMIN_WEBHOOK_SECRET=generate_a_long_random_secret
