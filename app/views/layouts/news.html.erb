<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for(:title) || "بی‌بی‌سی فارسی" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="icon" href="/icon.png" type="image/png">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.rtl.min.css" rel="stylesheet"
        integrity="sha384-PJsj/BG8Tzh8Kr/lukGD5C6Iuk52gFcs/onULULSwnT8/STzgFG2WLB53o7XHKMM" crossorigin="anonymous">
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">

  <style>
    :root { --bbc-red: #b80000; --bbc-ink: #141414; }
    body {
      font-family: "Vazirmatn", system-ui, sans-serif;
      background: #fff;
      color: var(--bbc-ink);
      line-height: 1.8;
    }
    .site-header {
      background: var(--bbc-ink);
      border-bottom: 4px solid var(--bbc-red);
    }
    .brand-mark {
      background: #fff;
      color: #000;
      font-weight: 800;
      letter-spacing: 2px;
      padding: 2px 8px;
      border-radius: 3px;
      font-family: system-ui, sans-serif;
    }
    .brand-name { color: #fff; font-weight: 700; font-size: 1.25rem; }
    a { text-decoration: none; }
    .story-card { border: 0; border-top: 1px solid #e7e7e7; border-radius: 0; }
    .story-card:hover .story-title { color: var(--bbc-red); }
    .story-title { color: var(--bbc-ink); font-weight: 700; transition: color .15s ease; }
    .story-summary { color: #404040; }
    .story-meta { color: #6b6b6b; font-size: .8rem; }
    .category-pill {
      color: var(--bbc-red);
      font-weight: 700;
      font-size: .8rem;
    }
    .lead-story .story-title { font-size: 1.9rem; line-height: 1.4; }
    .article-body { font-size: 1.12rem; color: #1a1a1a; }
    .article-body p { margin-bottom: 1.1rem; }
    .site-footer { background: var(--bbc-ink); color: #cfcfcf; }
  </style>
</head>
<body>
  <header class="site-header py-3">
    <div class="container d-flex align-items-center gap-3">
      <%= link_to root_path, class: "d-flex align-items-center gap-2" do %>
        <span class="brand-mark">BBC</span>
        <span class="brand-name">فارسی</span>
      <% end %>
    </div>
  </header>

  <main class="container py-4">
    <%= yield %>
  </main>

  <footer class="site-footer py-4 mt-5">
    <div class="container small">
      <span class="brand-mark">BBC</span>
      <span class="ms-2">بازنویسی و ترجمهٔ خودکار اخبار — نسخهٔ نمایشی</span>
    </div>
  </footer>
</body>
</html>
