<h2 class="mb-3">Translations</h2>

<%= render "admin/shared/filter_group",
      label: "Status", param: :status,
      options: Translation::STATUSES.map { |s| [s, s.capitalize] },
      counts: @status_counts,
      badge_class: ->(value) { "badge-status-#{value}" } %>
<% if @models.any? %>
  <%= render "admin/shared/filter_group",
        label: "Model", param: :model,
        options: @models.map { |model| [model, model] },
        counts: @model_counts %>
<% end %>
<div class="mb-2">
  <span class="text-muted small me-1">Other:</span>
  <%= render "admin/shared/filter_toggle", param: :active,      label: "Active only" %>
  <%= render "admin/shared/filter_toggle", param: :hide_posted, label: "Hide posted" %>
  <%= render "admin/shared/filter_toggle", param: :archived,    label: "Show archived" %>
</div>
<%= render "admin/shared/filter_search", placeholder: "Search article / Persian title…" %>

<%= form_with url: bulk_rerun_admin_translations_path, method: :post, id: "bulk_translations_form",
      class: "card card-body py-2 mb-3" do %>
  <div class="d-flex flex-wrap align-items-center gap-2">
    <span class="text-muted small">
      Bulk actions for <strong><span data-bulk-count="translations">0</span></strong> selected translation(s):
    </span>
    <button type="submit" formaction="<%= bulk_rerun_admin_translations_path %>" class="btn btn-sm btn-outline-warning">Retranslate</button>
    <button type="submit" formaction="<%= bulk_refine_admin_translations_path %>" class="btn btn-sm btn-outline-secondary">Refine</button>
  </div>
<% end %>

<table class="table table-hover table-sm">
  <thead>
    <tr>
      <th><input type="checkbox" data-bulk-select-all="translations" class="form-check-input" title="Select all"></th>
      <th><%= sort_link "article", "Article" %></th>
      <th><%= sort_link "title", "Persian Title" %></th>
      <th><%= sort_link "model", "Model" %></th>
      <th><%= sort_link "active", "Active" %></th>
      <th><%= sort_link "status", "Status" %></th>
      <th><%= sort_link "created", "Created" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @translations.each do |t| %>
      <tr class="<%= t.archived? ? 'table-secondary' : (t.active? ? 'table-success' : '') %>">
        <td>
          <%= check_box_tag "translation_ids[]", t.id, false,
                id: "translation_select_#{t.id}", form: "bulk_translations_form",
                class: "form-check-input bulk-select", data: { bulk_group: "translations" } %>
        </td>
        <td><small class="<%= 'posted-title' if t.article&.status == 'posted' %>"><%= t.article&.title&.truncate(50) %></small></td>
        <td dir="rtl"><%= t.translated_title&.truncate(50) %></td>
        <td><small class="text-muted"><%= t.llm_model %></small></td>
        <td>
          <% if t.archived? %>
            <span class="badge bg-secondary">Unpublished</span>
          <% elsif t.active? %>
            ✓
          <% end %>
        </td>
        <td><%= render "admin/shared/status_badge", status: t.status %></td>
        <td><small><%= t.created_at.strftime("%b %d %H:%M") %></small>
          <br />
          <small><%= t.updated_at.strftime("%b %d %H:%M") %></small></td>
        <td>
          <%= link_to "View / Post", admin_translation_path(t), class: "btn btn-xs btn-outline-success" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
