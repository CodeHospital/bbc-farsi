<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Translation</h2>
  <%= link_to "← Translations", admin_translations_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<% if @translation.article %>
  <p class="mb-3">
    <i class="bi bi-newspaper text-muted"></i>
    <%= link_to @translation.article.title, admin_article_path(@translation.article),
          class: "text-decoration-none" %>
  </p>
<% end %>

<% if @translation.status == "error" && @translation.error_message.present? %>
  <div class="alert alert-danger">
    <strong><i class="bi bi-exclamation-triangle-fill"></i> Job failed</strong>
    <pre class="mb-0 mt-2 small" style="white-space:pre-wrap"><%= @translation.error_message %></pre>
  </div>
<% end %>

<div class="card mb-3">
  <div class="card-header d-flex justify-content-between">
    <span>Persian output</span>
    <span><%= render "admin/shared/status_badge", status: @translation.status %></span>
  </div>
  <% if @translation.translated_title.present? || @translation.translated_body.present? %>
    <div class="card-body" dir="rtl" lang="fa">
      <h5><%= @translation.translated_title %></h5>
      <p><%= @translation.translated_body %></p>
    </div>
  <% elsif @translation.status == "running" %>
    <div class="card-body text-muted"><i class="bi bi-hourglass-split"></i> Translation in progress…</div>
  <% elsif @translation.status == "pending" %>
    <div class="card-body text-muted">Waiting to start.</div>
  <% end %>
  <div class="card-footer">
    <small class="text-muted">
      Model: <%= @translation.llm_model %> &bull;
      Prompt: <%= @translation.prompt_name %> &bull;
      <%= @translation.created_at.strftime("%b %d, %Y %H:%M") %>
    </small>
  </div>
</div>

<% if @translation.archived? %>
  <div class="alert alert-secondary d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-eye-slash-fill"></i>
    <span>This translation is <strong>unpublished</strong> — it is hidden from the public portal.</span>
    <%= button_to "Republish to portal", unarchive_admin_translation_path(@translation), method: :post,
          class: "btn btn-sm btn-outline-success ms-auto" %>
  </div>
<% end %>

<% if @translation.needs_manual_edit? %>
  <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-pencil-fill"></i>
    <span>This translation is <strong>flagged for manual editor review</strong>.</span>
    <%= button_to "Clear flag", toggle_manual_edit_admin_translation_path(@translation), method: :post,
          class: "btn btn-sm btn-outline-warning ms-auto" %>
  </div>
<% end %>

<div class="d-flex gap-2 mb-3 flex-wrap">
  <%= link_to "Edit", edit_admin_translation_path(@translation), class: "btn btn-outline-primary" %>
  <% unless @translation.archived? %>
    <%= button_to "✦ Refine Persian", refine_admin_translation_path(@translation), method: :post,
          class: "btn btn-outline-info",
          title: "Run AI refinement on the Persian text" %>
    <%= button_to "↺ Re-translate", rerun_admin_translation_path(@translation), method: :post,
          class: "btn btn-outline-warning" %>
    <% if @translation.status == "completed" && @translation.translated_title.present? %>
      <%= button_to "Unpublish from portal", archive_admin_translation_path(@translation), method: :post,
            class: "btn btn-outline-danger",
            data: { turbo_confirm: "Unpublish this translation? The previous version will be shown on the portal." } %>
    <% end %>
    <% unless @translation.needs_manual_edit? %>
      <%= button_to "✋ Flag for manual edit", toggle_manual_edit_admin_translation_path(@translation), method: :post,
            class: "btn btn-outline-warning" %>
    <% end %>
  <% end %>
  <% if @translation.article %>
    <%= button_to rewrite_admin_article_path(@translation.article), method: :post,
          class: "btn btn-outline-info" do %>
      <i class="bi bi-pencil-square"></i> Rewrite article
    <% end %>
  <% end %>
</div>

<div class="card mb-4">
  <div class="card-header"><i class="bi bi-terminal"></i> curl commands</div>
  <div class="card-body">
    <% if @translation.prompt_name == "refine" %>
      <p class="text-muted small mb-2">These commands refine the current Persian text.</p>
      <%= render "admin/shared/curl_block",
            label:   "refine title",
            command: TranslationRefiner.debug_curl_title(@translation,
                       server: @translation.ollama_server,
                       model:  @translation.llm_model) %>
      <%= render "admin/shared/curl_block",
            label:   "refine body",
            command: TranslationRefiner.debug_curl_body(@translation,
                       server: @translation.ollama_server,
                       model:  @translation.llm_model) %>
    <% else %>
      <p class="text-muted small mb-2">These are the exact calls used to produce this translation.</p>
      <%= render "admin/shared/curl_block",
            label:   "translate title",
            command: ArticleTranslator.debug_curl_title(@translation.rewrite,
                       server: @translation.ollama_server,
                       model:  @translation.llm_model) %>
      <%= render "admin/shared/curl_block",
            label:   "translate body",
            command: ArticleTranslator.debug_curl_body(@translation.rewrite,
                       server: @translation.ollama_server,
                       model:  @translation.llm_model) %>
    <% end %>
  </div>
</div>

<h5>Post to Telegram channel</h5>
<div class="row g-2">
  <% @telegram_channels.each do |channel| %>
    <div class="col-auto">
      <% already_posted = @posted_channel_ids.include?(channel.id) %>
      <%= button_to already_posted ? "✓ #{channel.name}" : "📤 #{channel.name}",
            post_to_channel_admin_translation_path(@translation),
            method: :post,
            params: { telegram_channel_id: channel.id },
            class: "btn #{already_posted ? 'btn-success' : 'btn-outline-success'}",
            disabled: already_posted %>
    </div>
  <% end %>
</div>

<%= render "history", versions: @versions %>
