<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Articles</h2>
  <%= button_to "▶ Fetch Feeds Now", admin_articles_path, method: :get,
        params: { trigger_fetch: 1 }, class: "btn btn-outline-primary" %>
</div>

<form class="row g-2 mb-3">
  <div class="col-auto">
    <%= select_tag :feed_id, options_from_collection_for_select(@feeds, :id, :name, params[:feed_id]),
          include_blank: "All feeds", class: "form-select form-select-sm" %>
  </div>
  <div class="col-auto">
    <%= select_tag :status, options_for_select(Article::STATUSES, params[:status]),
          include_blank: "All statuses", class: "form-select form-select-sm" %>
  </div>
  <div class="col-auto form-check mt-1 ms-1">
    <input type="checkbox" class="form-check-input" name="archived" value="1" id="show_archived"
           <%= params[:archived] == "1" ? "checked" : "" %>>
    <label class="form-check-label small" for="show_archived">Show archived</label>
  </div>
  <div class="col-auto">
    <button class="btn btn-sm btn-outline-secondary">Filter</button>
  </div>
</form>

<table class="table table-hover table-sm">
  <thead><tr><th>Title</th><th>Feed</th><th>Published</th><th>Status</th><th></th></tr></thead>
  <tbody>
    <% @articles.each do |article| %>
      <tr>
        <td>
          <%= link_to article.title.truncate(80), admin_article_path(article) %>
        </td>
        <td><span class="badge bg-secondary"><%= article.feed&.name %></span></td>
        <td><small><%= article.published_at&.strftime("%b %d %H:%M") %></small></td>
        <td><%= render "admin/shared/status_badge", status: article.status %></td>
        <td class="text-end">
          <%= button_to "Rewrite", rewrite_admin_article_path(article), method: :post,
                class: "btn btn-xs btn-outline-info me-1" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
