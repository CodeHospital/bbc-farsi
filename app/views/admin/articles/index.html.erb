<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Articles</h2>
  <%= button_to "▶ Fetch Feeds Now", admin_articles_path, method: :get,
        params: { trigger_fetch: 1 }, class: "btn btn-outline-primary" %>
</div>

<%= render "admin/shared/filter_group",
      label: "Status", param: :status,
      options: Article::STATUSES.map { |s| [s, s.capitalize] },
      counts: @status_counts,
      badge_class: ->(value) { "badge-status-#{value}" } %>
<%= render "admin/shared/filter_group",
      label: "Feed", param: :feed_id,
      options: @feeds.map { |feed| [feed.id, feed.name] },
      counts: @feed_counts %>
<div class="mb-2">
  <span class="text-muted small me-1">Other:</span>
  <%= render "admin/shared/filter_toggle", param: :hide_posted, label: "Hide posted" %>
  <%= render "admin/shared/filter_toggle", param: :archived, label: "Show archived" %>
</div>
<%= render "admin/shared/filter_search", placeholder: "Search title / description…" %>

<table class="table table-hover table-sm">
  <thead>
    <tr>
      <th><%= sort_link "title", "Title" %></th>
      <th><%= sort_link "feed", "Feed" %></th>
      <th><%= sort_link "published", "Published" %></th>
      <th><%= sort_link "status", "Status" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @articles.each do |article| %>
      <tr>
        <td>
          <%= link_to article.title.truncate(80), admin_article_path(article),
                class: ("posted-title" if article.status == "posted") %>
        </td>
        <td><span class="badge bg-secondary"><%= article.feed&.name %></span></td>
        <td><small><%= article.published_at&.strftime("%b %d %H:%M") %></small></td>
        <td><%= render "admin/shared/status_badge", status: article.status %></td>
        <td class="text-end">
          <%= button_to "Rewrite", rewrite_admin_article_path(article), method: :post,
                class: "btn btn-xs btn-outline-info me-1" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
