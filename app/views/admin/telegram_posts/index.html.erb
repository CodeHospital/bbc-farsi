<h2 class="mb-3">Telegram Posts</h2>
<table class="table table-hover table-sm">
  <thead>
    <tr>
      <th>Article</th>
      <th><%= sort_link "channel", "Channel" %></th>
      <th><%= sort_link "status", "Status" %></th>
      <th><%= sort_link "posted", "Posted at" %></th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.translation&.article&.title&.truncate(80) %></td>
        <td><span class="badge bg-secondary"><%= post.telegram_channel&.name %></span></td>
        <td><%= render "admin/shared/status_badge", status: post.status %></td>
        <td><small><%= post.posted_at&.strftime("%b %d %H:%M") || post.created_at.strftime("%b %d %H:%M") %></small>
          <br />
          <small><%= post.updated_at.strftime("%b %d %H:%M") %></small></td>
      </tr>
      <% if post.error_message.present? %>
        <tr>
          <td colspan="4" class="text-danger small py-0"><%= post.error_message %></td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
