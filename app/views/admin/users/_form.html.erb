<%= form_with model: [:admin, user] do |f| %>
  <% user.errors.full_messages.each do |msg| %>
    <div class="alert alert-danger"><%= msg %></div>
  <% end %>
  <div class="mb-3">
    <%= f.label :username, class: "form-label" %>
    <%= f.text_field :username, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
    <div class="form-text">Used for password reset emails.</div>
  </div>
  <div class="mb-3">
    <%= f.label :name, "Display name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :role, class: "form-label" %>
    <%= f.select :role, User::ROLES, {}, class: "form-select" %>
    <div class="form-text">Admins can manage feeds, channels, Ollama servers, users, and housekeeping. Editors get the editorial workflow (articles, rewrites, translations, tasks, analytics).</div>
  </div>
  <div class="mb-3">
    <%= f.label :password, user.new_record? ? "Password" : "New password", class: "form-label" %>
    <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
    <% unless user.new_record? %><div class="form-text">Leave blank to keep the current password.</div><% end %>
  </div>
  <div class="mb-3">
    <%= f.label :password_confirmation, class: "form-label" %>
    <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
  </div>
  <% if !user.new_record? %>
    <div class="form-check mb-3">
      <%= f.check_box :active, class: "form-check-input" %>
      <%= f.label :active, class: "form-check-label" %>
    </div>
  <% end %>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-secondary ms-2" %>
<% end %>
