<% if pagy.pages > 1 %>
  <% # Preserve any active filters (status, kind, search, …) across page links.
     page_url = ->(page) { url_for(request.query_parameters.merge(page: page)) } %>
  <nav class="mt-3">
    <ul class="pagination pagination-sm">
      <% if pagy.previous %>
        <li class="page-item">
          <%= link_to "«", page_url.call(pagy.previous), class: "page-link" %>
        </li>
      <% else %>
        <li class="page-item disabled"><span class="page-link">«</span></li>
      <% end %>

      <% pagy.send(:series).each do |item| %>
        <% case item %>
        <% when Integer %>
          <li class="page-item">
            <%= link_to item, page_url.call(item), class: "page-link" %>
          </li>
        <% when String %>
          <li class="page-item active" aria-current="page">
            <span class="page-link"><%= item %></span>
          </li>
        <% when :gap %>
          <li class="page-item disabled"><span class="page-link">…</span></li>
        <% end %>
      <% end %>

      <% if pagy.next %>
        <li class="page-item">
          <%= link_to "»", page_url.call(pagy.next), class: "page-link" %>
        </li>
      <% else %>
        <li class="page-item disabled"><span class="page-link">»</span></li>
      <% end %>
    </ul>
  </nav>
<% end %>
