<h2 class="mb-3">Rewrites</h2>
<table class="table table-hover table-sm">
  <thead><tr><th>Article</th><th>Model</th><th>Status</th><th>Created</th><th></th></tr></thead>
  <tbody>
    <% @rewrites.each do |rewrite| %>
      <tr>
        <td><%= link_to rewrite.article&.title&.truncate(70), admin_rewrite_path(rewrite) %></td>
        <td><small class="text-muted"><%= rewrite.llm_model %></small></td>
        <td><%= render "admin/shared/status_badge", status: rewrite.status %></td>
        <td><small><%= rewrite.created_at.strftime("%b %d %H:%M") %></small></td>
        <td>
          <%= link_to "Edit", edit_admin_rewrite_path(rewrite), class: "btn btn-xs btn-outline-primary me-1" %>
          <%= button_to "Rerun", rerun_admin_rewrite_path(rewrite), method: :post, class: "btn btn-xs btn-outline-warning" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
