<h2 class="mb-3">Rewrites</h2>

<%= render "admin/shared/filter_group",
      label: "Status", param: :status,
      options: Rewrite::STATUSES.map { |s| [s, s.capitalize] },
      counts: @status_counts,
      badge_class: ->(value) { "badge-status-#{value}" } %>
<div class="mb-2">
  <span class="text-muted small me-1">Other:</span>
  <%= render "admin/shared/filter_toggle", param: :archived, label: "Show archived" %>
</div>
<%= render "admin/shared/filter_search", placeholder: "Search article title / content…" %>

<table class="table table-hover table-sm">
  <thead>
    <tr>
      <th><%= sort_link "article", "Article" %></th>
      <th><%= sort_link "model", "Model" %></th>
      <th><%= sort_link "status", "Status" %></th>
      <th><%= sort_link "created", "Created" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @rewrites.each do |rewrite| %>
      <tr>
        <td><%= link_to rewrite.article&.title&.truncate(70), admin_rewrite_path(rewrite) %></td>
        <td><small class="text-muted"><%= rewrite.llm_model %></small></td>
        <td><%= render "admin/shared/status_badge", status: rewrite.status %></td>
        <td><small><%= rewrite.created_at.strftime("%b %d %H:%M") %></small>
          <br />
          <small><%= rewrite.updated_at.strftime("%b %d %H:%M") %></small></td>
        <td>
          <%= link_to "Edit", edit_admin_rewrite_path(rewrite), class: "btn btn-xs btn-outline-primary me-1" %>
          <%= button_to "Rerun", rerun_admin_rewrite_path(rewrite), method: :post, class: "btn btn-xs btn-outline-warning" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
