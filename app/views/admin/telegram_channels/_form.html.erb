<%= form_with model: [:admin, channel] do |f| %>
  <% channel.errors.full_messages.each do |msg| %>
    <div class="alert alert-danger"><%= msg %></div>
  <% end %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g. BBC Farsi Main" %>
  </div>
  <div class="mb-3">
    <%= f.label :token, "Bot Token", class: "form-label" %>
    <%= f.text_field :token, class: "form-control font-monospace", placeholder: "123456:ABC-..." %>
  </div>
  <div class="mb-3">
    <%= f.label :channel_id, "Channel ID", class: "form-label" %>
    <%= f.text_field :channel_id, class: "form-control", placeholder: "@mychannel or -100..." %>
  </div>
  <div class="form-check mb-2">
    <%= f.check_box :enabled, class: "form-check-input" %>
    <%= f.label :enabled, class: "form-check-label" %>
  </div>
  <div class="form-check mb-3">
    <%= f.check_box :autopost, class: "form-check-input" %>
    <%= f.label :autopost, "Enable autoposting (post new translations automatically)", class: "form-check-label" %>
  </div>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", admin_telegram_channels_path, class: "btn btn-outline-secondary ms-2" %>
<% end %>
