<h2 class="mb-3">Task Queue</h2>

<%= render "admin/shared/filter_group",
      label: "Status", param: :status,
      options: Task::STATUSES.map { |s| [s, s.capitalize] },
      counts: @counts, cross_counts: @status_counts_in_kind,
      badge_class: ->(value) { "badge-status-#{value}" } %>
<%= render "admin/shared/filter_group",
      label: "Kind", param: :kind,
      options: Task::KINDS.map { |k| [k, k.capitalize] },
      counts: @kind_counts, cross_counts: @kind_counts_in_status %>
<%= render "admin/shared/filter_search", placeholder: "Search article title / description…" %>

<p class="text-muted small">
  Tasks are claimed and processed by an external worker client over the protected
  task API. Nothing is processed here in the web app.
</p>

<%= form_with url: bulk_prioritize_admin_tasks_path, method: :patch, id: "bulk_priority_form",
      class: "card card-body py-2 mb-3" do %>
  <div class="d-flex flex-wrap align-items-center gap-2">
    <span class="text-muted small">
      Bulk priority for <strong><span data-bulk-count="tasks">0</span></strong> selected:
    </span>
    <button type="submit" name="direction" value="up" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-up"></i> Raise
    </button>
    <button type="submit" name="direction" value="down" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-down"></i> Lower
    </button>
    <span class="vr d-none d-sm-block"></span>
    <div class="input-group input-group-sm" style="width:auto">
      <input type="number" name="priority" class="form-control form-control-sm" style="max-width:90px" placeholder="Set to…">
      <button type="submit" class="btn btn-sm btn-outline-secondary">Apply</button>
    </div>
  </div>
<% end %>

<table class="table table-hover table-sm align-middle">
  <thead>
    <tr>
      <th><input type="checkbox" data-bulk-select-all="tasks" class="form-check-input" title="Select all"></th>
      <th>#</th>
      <th><%= sort_link "priority", "Priority" %></th>
      <th><%= sort_link "kind", "Kind" %></th>
      <th>Article</th>
      <th>Server / Model</th>
      <th><%= sort_link "status", "Status" %></th>
      <th><%= sort_link "attempts", "Attempts" %></th>
      <th><%= sort_link "created", "Created" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <%= render @tasks %>
  </tbody>
</table>
<%= render "admin/shared/pagination", pagy: @pagy %>
