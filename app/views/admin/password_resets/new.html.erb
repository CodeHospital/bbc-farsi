<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>BBC Farsi Admin — Forgot password</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-dark d-flex align-items-center justify-content-center" style="min-height:100vh">
  <div class="card shadow" style="width:360px">
    <div class="card-body p-4">
      <h4 class="card-title text-center mb-4">📡 Forgot password</h4>

      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == 'alert' ? 'danger' : 'success' %>"><%= message %></div>
      <% end %>

      <p class="small text-muted">Enter your account email and we'll send you a link to reset your password.</p>

      <%= form_with url: admin_password_resets_path, method: :post do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control", autofocus: true, autocomplete: "email" %>
        </div>
        <%= f.submit "Send reset link", class: "btn btn-primary w-100" %>
      <% end %>
      <div class="text-center mt-3">
        <%= link_to "Back to login", admin_login_path, class: "small text-muted" %>
      </div>
    </div>
  </div>
</body>
</html>
