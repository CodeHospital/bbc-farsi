<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Feeds</h2>
  <div>
    <%= button_to "Seed BBC Feeds", seed_admin_feeds_path, method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= link_to "New Feed", new_admin_feed_path, class: "btn btn-primary" %>
  </div>
</div>

<table class="table table-hover">
  <thead>
    <tr>
      <th><%= sort_link "name", "Name" %></th>
      <th><%= sort_link "category", "Category" %></th>
      <th>URL</th>
      <th>Articles</th>
      <th><%= sort_link "enabled", "Status" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @feeds.each do |feed| %>
      <tr>
        <td><%= feed.name %></td>
        <td><span class="badge bg-secondary"><%= feed.category %></span></td>
        <td><small class="text-muted"><%= feed.url %></small></td>
        <td><%= link_to feed.articles.count, admin_articles_path(feed_id: feed.id) %></td>
        <td>
          <%= button_to feed.enabled? ? "Disable" : "Enable",
                toggle_admin_feed_path(feed), method: :patch,
                class: "btn btn-sm #{feed.enabled? ? 'btn-success' : 'btn-outline-secondary'}" %>
        </td>
        <td>
          <%= link_to "Edit", edit_admin_feed_path(feed), class: "btn btn-sm btn-outline-primary me-1" %>
          <%= button_to "Delete", admin_feed_path(feed), method: :delete,
                class: "btn btn-sm btn-outline-danger",
                data: { turbo_confirm: "Delete this feed?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
