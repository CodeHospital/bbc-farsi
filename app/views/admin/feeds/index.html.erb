<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Feeds</h2>
  <div>
    <%= button_to "Seed BBC Feeds", seed_admin_feeds_path, method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= button_to "Seed NYT Feeds", seed_admin_feeds_path(source: "nyt"), method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= link_to "New Feed", new_admin_feed_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @fetch_result %>
  <div class="card mb-3">
    <div class="card-header">Fetch results — <%= @feed.name %></div>
    <div class="card-body">
      <% if @fetch_result[:error] %>
        <p class="text-danger mb-0">Failed: <%= @fetch_result[:error] %></p>
      <% else %>
        <p class="mb-2">
          <span class="badge bg-success">New: <%= @fetch_result[:new_count] %></span>
          <span class="badge bg-primary">Updated: <%= @fetch_result[:updated_count] %></span>
          <span class="badge bg-secondary">Skipped: <%= @fetch_result[:skipped].size %></span>
        </p>
        <% if @fetch_result[:skipped].any? %>
          <div style="max-height: 300px; overflow-y: auto;">
            <table class="table table-sm mb-0">
              <thead><tr><th>Title</th><th>Reason skipped</th></tr></thead>
              <tbody>
                <% @fetch_result[:skipped].each do |item| %>
                  <tr>
                    <td><%= item[:title] %></td>
                    <td class="text-muted"><small><%= item[:reason] %></small></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<table class="table table-hover">
  <thead>
    <tr>
      <th><%= sort_link "name", "Name" %></th>
      <th><%= sort_link "category", "Category" %></th>
      <th><%= sort_link "source", "Source" %></th>
      <th>URL</th>
      <th>Articles</th>
      <th><%= sort_link "enabled", "Status" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @feeds.each do |feed| %>
      <tr>
        <td><%= feed.name %></td>
        <td><span class="badge bg-secondary"><%= feed.category %></span></td>
        <td><span class="badge bg-info text-dark"><%= feed.source %></span></td>
        <td><small class="text-muted"><%= feed.url %></small></td>
        <td><%= link_to feed.articles.count, admin_articles_path(feed_id: feed.id) %></td>
        <td>
          <%= button_to feed.enabled? ? "Disable" : "Enable",
                toggle_admin_feed_path(feed), method: :patch,
                class: "btn btn-sm #{feed.enabled? ? 'btn-success' : 'btn-outline-secondary'}" %>
        </td>
        <td>
          <%= button_to "Fetch", fetch_admin_feed_path(feed), method: :post,
                class: "btn btn-sm btn-outline-info me-1" %>
          <%= link_to "Edit", edit_admin_feed_path(feed), class: "btn btn-sm btn-outline-primary me-1" %>
          <%= button_to "Delete", admin_feed_path(feed), method: :delete,
                class: "btn btn-sm btn-outline-danger",
                data: { turbo_confirm: "Delete this feed?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
