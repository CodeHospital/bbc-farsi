<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Feeds</h2>
  <div>
    <%= button_to "Seed BBC Feeds", seed_admin_feeds_path, method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= button_to "Seed NYT Feeds", seed_admin_feeds_path(source: "nyt"), method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= button_to "Seed Ad Hoc News Feeds", seed_admin_feeds_path(source: "adhocnews"), method: :post,
          class: "btn btn-outline-secondary me-2" %>
    <%= link_to "New Feed", new_admin_feed_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @fetch_result %>
  <div class="card mb-3">
    <div class="card-header">Fetch results — <%= @feed.name %></div>
    <div class="card-body">
      <% if @fetch_result[:error] %>
        <p class="text-danger mb-0">Failed: <%= @fetch_result[:error] %></p>
      <% else %>
        <p class="mb-2">
          <span class="badge bg-success">New: <%= @fetch_result[:new_count] %></span>
          <span class="badge bg-primary">Updated: <%= @fetch_result[:updated_count] %></span>
          <span class="badge bg-secondary">Skipped: <%= @fetch_result[:skipped].size %></span>
        </p>
        <% if @fetch_result[:skipped].any? %>
          <div style="max-height: 300px; overflow-y: auto;">
            <table class="table table-sm mb-0">
              <thead><tr><th>Title</th><th>Reason skipped</th></tr></thead>
              <tbody>
                <% @fetch_result[:skipped].each do |item| %>
                  <tr>
                    <td><%= item[:title] %></td>
                    <td class="text-muted"><small><%= item[:reason] %></small></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<table class="table table-hover">
  <thead>
    <tr>
      <th><%= sort_link "name", "Name" %></th>
      <th><%= sort_link "category", "Category" %></th>
      <th><%= sort_link "source", "Source" %></th>
      <th>URL</th>
      <th>Articles</th>
      <th><%= sort_link "enabled", "Status" %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <%= render @feeds %>
  </tbody>
</table>
