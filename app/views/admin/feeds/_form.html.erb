<%= form_with model: [:admin, feed], class: "needs-validation" do |f| %>
  <% feed.errors.full_messages.each do |msg| %>
    <div class="alert alert-danger"><%= msg %></div>
  <% end %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :url, class: "form-label" %>
    <%= f.url_field :url, class: "form-control" %>
  </div>
  <div class="mb-3">
    <%= f.label :category, class: "form-label" %>
    <%= f.text_field :category, class: "form-control" %>
  </div>
  <div class="form-check mb-3">
    <%= f.check_box :enabled, class: "form-check-input" %>
    <%= f.label :enabled, class: "form-check-label" %>
  </div>
  <%= f.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", admin_feeds_path, class: "btn btn-outline-secondary ms-2" %>
<% end %>
