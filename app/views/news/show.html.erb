<% published_at = @article.published_at || @translation.created_at %>
<% title = story_title(@translation) %>
<% body  = story_body(@translation) %>
<% summary = body.to_s.squish.truncate(160) %>
<% content_for :title, "#{title} — #{news_ui(:site_name)}" %>
<% content_for :description, summary %>
<% content_for :canonical, news_story_url(@translation) %>
<% content_for :og_type, "article" %>
<% content_for :og_image, @image_url if @image_url.present? %>

<% content_for :head do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      headline: title,
      description: summary,
      inLanguage: (english_edition? ? "en" : "fa"),
      image: (@image_url.presence ? [@image_url] : nil),
      datePublished: published_at&.iso8601,
      dateModified: @translation.updated_at.iso8601,
      keywords: (@tags.presence&.join(", ")),
      articleSection: category_name(@article.feed&.category),
      mainEntityOfPage: { "@type": "WebPage", "@id": news_story_url(@translation) },
      publisher: { "@type": "Organization", name: news_ui(:site_name) }
    }.compact.to_json) %>
  </script>
<% end %>

<nav class="mb-3 small text-muted">
  <%= link_to news_ui(:home), root_path %>
  <i class="bi bi-chevron-left mx-1" style="font-size:.7rem"></i>
  <%= link_to category_name(@article.feed&.category), category_path(@article.feed&.category) %>
</nav>

<article style="<%= category_style(@article.feed&.category) %>">
  <span class="cat-label flat"><%= category_name(@article.feed&.category) %></span>
  <h1 class="fw-bold my-2" style="line-height:1.6"><%= title %></h1>
  <div class="text-muted mb-3" style="font-size:.85rem">
    <i class="bi bi-clock"></i> <%= story_timestamp(@article.published_at || @translation.created_at) %>
  </div>

  <% if @image_url.present? %>
    <figure class="article-figure mb-4">
      <%= image_tag @image_url, alt: title, loading: "lazy" %>
    </figure>
  <% end %>

  <div class="article-body">
    <%= simple_format(body) %>
  </div>

  <% if @tags.any? %>
    <div class="article-tags mt-4 pt-3 border-top">
      <span class="tags-label"><%= news_ui(:tags_label) %></span>
      <% @tags.each do |tag| %>
        <span class="tag-chip"><%= tag %></span>
      <% end %>
    </div>
  <% end %>

  <div class="mt-4 pt-3 border-top">
    <%= link_to news_ui(:read_source), @article.url,
          target: "_blank", rel: "noopener", class: "cat-label flat fw-bold" %>
  </div>
</article>
