<% content_for :title, "#{@translation.translated_title} вҖ” ШЁЫҢвҖҢШЁЫҢвҖҢШіЫҢ ЩҒШ§ШұШіЫҢ" %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <nav class="mb-3">
      <%= link_to "вҶ’ ШЁШ§ШІЪҜШҙШӘ ШЁЩҮ ШөЩҒШӯЩҮЩ” Ш§ШөЩ„ЫҢ", root_path, class: "category-pill" %>
    </nav>

    <article>
      <div class="category-pill mb-2"><%= category_name_fa(@article.feed&.category) %></div>
      <h1 class="story-title mb-3"><%= @translation.translated_title %></h1>
      <div class="story-meta mb-4 pb-3 border-bottom">
        <%= story_timestamp(@article.published_at || @translation.created_at) %>
      </div>

      <div class="article-body">
        <%= simple_format(@translation.translated_body) %>
      </div>

      <div class="mt-4 pt-3 border-top">
        <%= link_to "Щ…ШҙШ§ЩҮШҜЩҮЩ” Ш®ШЁШұ Ш§ШөЩ„ЫҢ ШҜШұ bbc.com вҶ—", @article.url,
              target: "_blank", rel: "noopener", class: "category-pill" %>
      </div>
    </article>
  </div>
</div>
