<% if @category %>
  <% content_for :title, "#{category_name(@category)} — #{news_ui(:site_name)}" %>
<% else %>
  <% content_for :title, "#{news_ui(:site_name)} — #{news_ui(:latest_news)}" %>
<% end %>

<% content_for :head do %>
  <%# WebSite schema with SearchAction so Google can show a sitelinks search box %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "#{root_url}#website",
          name: news_ui(:site_name),
          url: root_url,
          description: (english_edition? ?
            "Automatic rewriting and translation of BBC news into Persian." :
            "بازنویسی و ترجمهٔ خودکار اخبار بی‌بی‌سی به فارسی."),
          inLanguage: [english_edition? ? "en" : "fa"],
          potentialAction: {
            "@type": "SearchAction",
            target: {
              "@type": "EntryPoint",
              urlTemplate: "#{news_search_url}{search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        (@all_stories.first(10).each_with_index.map do |story, idx|
          {
            "@type": "ListItem",
            position: idx + 1,
            url: news_story_url(story),
            name: story_title(story)
          }
        end.then do |items|
          {
            "@type": "ItemList",
            "@id": "#{root_url}#top-stories",
            name: news_ui(:latest_news),
            itemListElement: items
          }
        end)
      ]
    }.to_json) %>
  </script>
<% end %>

<% if @featured.empty? && @rest.empty? %>
  <div class="text-center text-muted py-5">
    <h4><%= news_ui(:empty_title) %></h4>
    <p><%= news_ui(:empty_body) %></p>
  </div>
<% else %>
  <% if @category %>
    <h1 class="block-title" style="<%= category_style(@category) %>"><span><%= category_name(@category) %></span></h1>
  <% end %>

  <%# ── Mosaic hero: one big lead + up to four overlay tiles ─────────────── %>
  <% lead = @featured.first %>
  <% tiles = @featured.drop(1).first(4) %>
  <% if lead %>
    <div class="mosaic mb-4">
      <div class="lead">
        <%= render "news/overlay_card", story: lead, image_url: @image_urls[lead.article.id], hero: true %>
      </div>
      <% tiles.each do |story| %>
        <%= render "news/overlay_card", story: story, image_url: @image_urls[story.article.id], tile: true %>
      <% end %>
    </div>
  <% end %>

  <%# ── Category page: flat list ─────────────────────────────────────────── %>
  <% if @category %>
    <section>
      <% @rest.each do |story| %>
        <%= render "news/post_item", story: story, image_url: @image_urls[story.article.id] %>
      <% end %>
    </section>
    <% if @rest.empty? && @featured.size <= 1 %>
      <p class="text-muted mt-3"><%= news_ui(:empty_cat) %></p>
    <% end %>
  <% else %>
    <%# ── Homepage: category modules (big lead + thumbnail list) ─────────── %>
    <% @sections.each_with_index do |(category, stories), section_idx| %>
      <% next if stories.empty? %>
      <% module_lead = stories.first %>
      <% module_rest = stories.drop(1) %>
      <section class="mb-5">
        <h2 class="block-title" style="<%= category_style(category) %>">
          <%= link_to category_path(category: category) do %><span><%= category_name(category) %></span><% end %>
          <%= link_to news_ui(:more), category_path(category: category), class: "more" %>
        </h2>
        <%# First category module lead loads eagerly — it's likely above the fold %>
        <%= render "news/module_lead", story: module_lead,
              image_url: @image_urls[module_lead.article.id],
              eager: section_idx == 0 %>
        <% module_rest.each do |story| %>
          <%= render "news/post_item", story: story, image_url: @image_urls[story.article.id], excerpt: false %>
        <% end %>
      </section>
    <% end %>
  <% end %>
<% end %>
