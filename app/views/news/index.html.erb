<% if @category %>
  <% content_for :title, "#{category_name(@category)} — #{news_ui(:site_name)}" %>
<% else %>
  <% content_for :title, "#{news_ui(:site_name)} — #{news_ui(:latest_news)}" %>
<% end %>

<% if @featured.empty? && @rest.empty? %>
  <div class="text-center text-muted py-5">
    <h4><%= news_ui(:empty_title) %></h4>
    <p><%= news_ui(:empty_body) %></p>
  </div>
<% else %>
  <% if @category %>
    <h1 class="block-title" style="<%= category_style(@category) %>"><span><%= category_name(@category) %></span></h1>
  <% end %>

  <%# ── Mosaic hero: one big lead + up to four overlay tiles ─────────────── %>
  <% lead = @featured.first %>
  <% tiles = @featured.drop(1).first(4) %>
  <% if lead %>
    <div class="mosaic mb-4">
      <div class="lead">
        <%= render "news/overlay_card", story: lead, image_url: @image_urls[lead.article.id], hero: true %>
      </div>
      <% tiles.each do |story| %>
        <%= render "news/overlay_card", story: story, image_url: @image_urls[story.article.id], tile: true %>
      <% end %>
    </div>
  <% end %>

  <%# ── Category page: flat list ─────────────────────────────────────────── %>
  <% if @category %>
    <section>
      <% @rest.each do |story| %>
        <%= render "news/post_item", story: story, image_url: @image_urls[story.article.id] %>
      <% end %>
    </section>
    <% if @rest.empty? && @featured.size <= 1 %>
      <p class="text-muted mt-3"><%= news_ui(:empty_cat) %></p>
    <% end %>
  <% else %>
    <%# ── Homepage: category modules (big lead + thumbnail list) ─────────── %>
    <% @sections.each do |category, stories| %>
      <% next if stories.empty? %>
      <% module_lead = stories.first %>
      <% module_rest = stories.drop(1) %>
      <section class="mb-5">
        <h2 class="block-title" style="<%= category_style(category) %>">
          <%= link_to category_path(category) do %><span><%= category_name(category) %></span><% end %>
          <%= link_to news_ui(:more), category_path(category), class: "more" %>
        </h2>
        <%= render "news/module_lead", story: module_lead, image_url: @image_urls[module_lead.article.id] %>
        <% module_rest.each do |story| %>
          <%= render "news/post_item", story: story, image_url: @image_urls[story.article.id], excerpt: false %>
        <% end %>
      </section>
    <% end %>
  <% end %>
<% end %>
